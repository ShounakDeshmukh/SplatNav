# /workspace/justfile

default:
    @just --list

# Build the ROS2 workspace
build:
    colcon build --symlink-install

# Build only the GauSS-MI package.
build-gaussmi:
    colcon build --packages-select gs_mapping --symlink-install

# Run a command with ROS and ros2_rust environments sourced
source-ros cmd:
    bash -lc 'source /opt/ros/jazzy/setup.bash && source /opt/ros2_rust_ws/install/setup.bash && {{cmd}}'

# Run the Rust cmd_vel publisher node
run-rust: (source-ros "cd /workspace && colcon build --packages-select spin_robot_node --symlink-install && source /workspace/install/setup.bash && ros2 run spin_robot_node spin_robot_node")

# Launch the Jackal simulation using hardware OpenGL by default.
# `renderer` can be `ogre` or `ogre2`.
launch-sim rviz="" renderer="ogre2" extra_args="":
    mkdir -p /tmp/runtime-root && chmod 700 /tmp/runtime-root
    XDG_RUNTIME_DIR=/tmp/runtime-root \
    GZ_PARTITION=jackal_sim \
    IGN_PARTITION=jackal_sim \
    GZ_IP=127.0.0.1 \
    IGN_IP=127.0.0.1 \
    QT_X11_NO_MITSHM=1 \
    LIBGL_ALWAYS_SOFTWARE=0 \
    __GLX_VENDOR_LIBRARY_NAME=nvidia \
    GZ_RENDER_ENGINE={{renderer}} \
    IGN_RENDER_ENGINE={{renderer}} \
        ros2 launch clearpath_gz simulation.launch.py {{ if rviz == "rviz" { "rviz:=true" } else { rviz } }} {{extra_args}}

# Launch without RViz and request headless Gazebo mode when supported.
launch-sim-headless:
    just launch-sim "rviz:=false" "ogre2" "headless:=true gui:=false"

# Launch with software rendering (use only when hardware GL is unavailable).
launch-sim-software rviz="" renderer="ogre" extra_args="":
    mkdir -p /tmp/runtime-root && chmod 700 /tmp/runtime-root
    XDG_RUNTIME_DIR=/tmp/runtime-root \
    GZ_PARTITION=jackal_sim \
    IGN_PARTITION=jackal_sim \
    GZ_IP=127.0.0.1 \
    IGN_IP=127.0.0.1 \
    QT_X11_NO_MITSHM=1 \
    LIBGL_ALWAYS_SOFTWARE=1 \
    MESA_LOADER_DRIVER_OVERRIDE=llvmpipe \
    GZ_RENDER_ENGINE={{renderer}} \
    IGN_RENDER_ENGINE={{renderer}} \
        ros2 launch clearpath_gz simulation.launch.py {{ if rviz == "rviz" { "rviz:=true" } else { rviz } }} {{extra_args}}

# List available ROS2 topics
topics:
    ros2 topic list

# Launch foxglove bridge
launch-foxglove:
    ros2 launch foxglove_bridge foxglove_bridge_launch.xml

# Launch GauSS-MI with active reconstruction config.
launch-gaussmi-active:
    bash -lc 'source /opt/ros/jazzy/setup.bash && cd /home/sdeshmu4/RustSplatNav/ros2_ws && source install/setup.bash && ros2 launch gs_mapping gaussmi_active.launch.py'

# Launch GauSS-MI with rosbag config.
launch-gaussmi-rosbag:
    bash -lc 'source /opt/ros/jazzy/setup.bash && cd /home/sdeshmu4/RustSplatNav/ros2_ws && source install/setup.bash && ros2 launch gs_mapping gaussmi_rosbag_oildrum.launch.py'