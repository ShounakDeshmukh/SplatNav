# /workspace/justfile

default:
    @just --list

# Build the ROS2 workspace
build:
    colcon build --symlink-install

# Run a command with ROS sourced
source-ros cmd:
    bash --noprofile --norc -c 'source /opt/ros/jazzy/setup.bash && {{cmd}}'

# Run the Python controller node. Set mode=nbv to chase /gaussmi/nbv_pose.
run-controller mode="spin": (source-ros "cd /workspace && colcon build --packages-select spin_robot_node --symlink-install && source /workspace/install/setup.bash && ros2 run spin_robot_node spin_robot_node --ros-args -p mode:={{mode}}")

# Launch Nav2 + NBV bridge for active demo.
launch-nav2-nbv:
    bash --noprofile --norc -c 'source /opt/ros/jazzy/setup.bash && cd /workspace && colcon build --packages-select spin_robot_node --symlink-install && source install/setup.bash && ros2 launch spin_robot_node nav2_nbv_demo.launch.py'

# Launch the Jackal simulation using hardware OpenGL by default.
# `renderer` can be `ogre` or `ogre2`.
launch-sim rviz="" renderer="ogre2" extra_args="":
    bash --noprofile --norc -c 'source /opt/ros/jazzy/setup.bash && mkdir -p /tmp/runtime-root && chmod 700 /tmp/runtime-root && XDG_RUNTIME_DIR=/tmp/runtime-root GZ_PARTITION=jackal_sim IGN_PARTITION=jackal_sim GZ_IP=127.0.0.1 IGN_IP=127.0.0.1 QT_X11_NO_MITSHM=1 LIBGL_ALWAYS_SOFTWARE=0 __GLX_VENDOR_LIBRARY_NAME=nvidia GZ_RENDER_ENGINE={{renderer}} IGN_RENDER_ENGINE={{renderer}} ros2 launch clearpath_gz simulation.launch.py {{ if rviz == "rviz" { "rviz:=true" } else { rviz } }} {{extra_args}}'

# Launch without RViz and request headless Gazebo mode when supported.
launch-sim-headless:
    just launch-sim "rviz:=false" "ogre2" "headless:=true gui:=false"

# Launch with software rendering (use only when hardware GL is unavailable).
launch-sim-software rviz="" renderer="ogre" extra_args="":
    bash --noprofile --norc -c 'source /opt/ros/jazzy/setup.bash && mkdir -p /tmp/runtime-root && chmod 700 /tmp/runtime-root && XDG_RUNTIME_DIR=/tmp/runtime-root GZ_PARTITION=jackal_sim IGN_PARTITION=jackal_sim GZ_IP=127.0.0.1 IGN_IP=127.0.0.1 QT_X11_NO_MITSHM=1 LIBGL_ALWAYS_SOFTWARE=1 MESA_LOADER_DRIVER_OVERRIDE=llvmpipe GZ_RENDER_ENGINE={{renderer}} IGN_RENDER_ENGINE={{renderer}} ros2 launch clearpath_gz simulation.launch.py {{ if rviz == "rviz" { "rviz:=true" } else { rviz } }} {{extra_args}}'

# List available ROS2 topics
topics:
    ros2 topic list

# Launch foxglove bridge
launch-foxglove:
    ros2 launch foxglove_bridge foxglove_bridge_launch.xml

# Bring up the ROS 2 container, the ROS 2 relay, and the ROS 1 GauSS-MI container.
compose-up-gaussmi:
    docker compose -f ../docker/docker-compose.yml up -d --build ros2 gaussmi_relay gaussmi_ros1

# Shut down the GauSS-MI stack.
compose-down-gaussmi:
    docker compose -f ../docker/docker-compose.yml down
